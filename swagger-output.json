{
  "swagger": "2.0",
  "info": {
    "title": "PhonePe API",
    "version": "1.0.0",
    "description": "API documentation for PhonePe integration project"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Check server sahi hai",
        "responses": {
          "200": {
            "description": "Server is running"
          }
        }
      }
    },

    "/api/auth/register": {
      "post": {
        "summary": "Register user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "username": "vikas",
                "email": "vikas@gmail.com",
                "password": "123456",
                "role": "artist"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully"
          }
        }
      }
    }

  }
}